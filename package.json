{
  "name": "steveroberts-me",
  "version": "1.0.0",
  "private": true,
  "description": "Personal site of Steve Roberts — engineering, systems, APIs.",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve --port=8082",
    "watch": "eleventy --serve --watch --port=8082",
    "clean": "rm -rf _site",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "prettier": "^3.8.3"
  }
}
