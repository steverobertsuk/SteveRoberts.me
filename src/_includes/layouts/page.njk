---
layout: layouts/base.njk
---
<article class="page">
  <header class="page-header">
    <div class="container">
      {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
      <h1>{{ title }}</h1>
      {% if lede %}<p class="lede">{{ lede }}</p>{% endif %}
    </div>
  </header>

  <div class="container prose">
    {{ content | safe }}
  </div>
</article>
