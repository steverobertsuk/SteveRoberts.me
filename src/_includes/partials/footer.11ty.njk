<footer class="site-footer">
  <div class="container site-footer__inner">
    <div class="site-footer__brand">
      <strong>{{ site.title }}</strong>
      <span>{{ site.tagline }}</span>
    </div>
    <nav class="site-footer__links" aria-label="Footer">
      <ul>
        <li>
          <a href="{{ site.social.github }}" rel="me noopener">
            <i class="fa-brands fa-github fa-fw" aria-hidden="true"></i>
            <span>GitHub</span></a>
        </li>
        <li>
          <a href="{{ site.social.linkedin }}" rel="me noopener">
            <i class="fa-brands fa-linkedin fa-fw" aria-hidden="true"></i>
            <span>LinkedIn</span></a>
        </li>
        <li>
          <a href="{{ site.social.holosuite }}" rel="noopener">
            <i class="fa-solid fa-podcast fa-fw" aria-hidden="true"></i>
            <span>Holosuite Media</span></a>
        </li>
        <li>
          <a href="{{ site.social.gaming }}" rel="noopener">
            <i class="fa-solid fa-gamepad fa-fw" aria-hidden="true"></i>
            <span>Gaming</span></a>
        </li>
        <li>
          <a href="{{ site.social.shadow }}" rel="noopener">
            <i class="fa-solid fa-computer fa-fw" aria-hidden="true"></i>
            <span>Shadow Computers</span></a>
        </li>
      </ul>
    </nav>
    <p class="site-footer__meta">
      &copy; {% year %}
      {{ site.author }}
      · <a href="/">Home</a>
      · <a href="/projects/">Projects</a>
      · <a href="/contact/">Contact</a>
      · <a href="/privacy/">Privacy Policy</a>
      {% if site.gaId %} · <a href="#" id="cookie-prefs-link">Cookie Preferences</a>{% endif %}
    </p>
  </div>
</footer>
