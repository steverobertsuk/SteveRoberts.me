<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="{{ site.title }} — home">
      <span class="brand__mark" aria-hidden="true">
        <img src="/assets/img/sr-monogram-flat.svg" width="36" height="36" alt=""/>
      </span>
      <span class="brand__text">
        <span class="brand__name">{{ site.title }}</span>
        <span class="brand__tag">{{ site.tagline }}</span>
      </span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false"
            aria-controls="site-nav" aria-label="Toggle navigation">
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Primary">
      <ul>
        {% for item in site.nav %}
          {% set isActive = (page.url == item.url)or(item.url != '/' and page.url.startsWith(item.url)) %}
          {% set iconClass = 'fa-solid fa-link' %}
          {% if item.url == '/' %}
            {% set iconClass = 'fa-solid fa-house' %}
          {% elif item.url == '/projects/' %}
            {% set iconClass = 'fa-solid fa-diagram-project' %}
          {% elif item.url == '/experience/' %}
            {% set iconClass = 'fa-solid fa-briefcase' %}
          {% elif item.url == '/media/' %}
            {% set iconClass = 'fa-solid fa-photo-film' %}
          {% elif item.url == '/running/' %}
            {% set iconClass = 'fa-solid fa-person-running' %}
          {% elif item.url == '/now/' %}
            {% set iconClass = 'fa-solid fa-clock' %}
          {% elif item.url == '/contact/' %}
            {% set iconClass = 'fa-solid fa-envelope' %}
          {% endif %}
          <li>
            <a href="{{ item.url }}"{% if isActive %} aria-current="page"{% endif %}>
              <i class="{{ iconClass }} fa-fw" aria-hidden="true"></i>
              <span>{{ item.label }}</span>
            </a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
