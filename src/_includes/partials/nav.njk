<header class="site-header">
  <div class="container site-header__inner">
    <a class="brand" href="/" aria-label="{{ site.title }} — home">
      <span class="brand__mark" aria-hidden="true">
        <svg viewBox="0 0 64 64" width="36" height="36" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="sr-grad" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#60A5FA" />
              <stop offset="100%" stop-color="#2563EB" />
            </linearGradient>
          </defs>
          <rect x="2" y="2" width="60" height="60" rx="14" ry="14"
                fill="none" stroke="url(#sr-grad)" stroke-width="2" opacity="0.55" />
          <text x="50%" y="56%" text-anchor="middle" dominant-baseline="middle"
                font-family="Inter, system-ui, sans-serif" font-weight="700"
                font-size="28" fill="url(#sr-grad)" letter-spacing="-1">SR</text>
        </svg>
      </span>
      <span class="brand__text">
        <span class="brand__name">{{ site.title }}</span>
        <span class="brand__tag">{{ site.tagline }}</span>
      </span>
    </a>

    <button class="nav-toggle" type="button" aria-expanded="false"
            aria-controls="site-nav" aria-label="Toggle navigation">
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
      <span class="nav-toggle__bar"></span>
    </button>

    <nav id="site-nav" class="site-nav" aria-label="Primary">
      <ul>
        {% for item in site.nav %}
          {% set isActive = (page.url == item.url) or (item.url != '/' and page.url.startsWith(item.url)) %}
          <li>
            <a href="{{ item.url }}"{% if isActive %} aria-current="page"{% endif %}>{{ item.label }}</a>
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
